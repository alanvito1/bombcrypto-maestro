# ==========================================
# 🌹 AVRE INITIATION SEQUENCE
# ==========================================
# CENTRAL CONTROL PANEL
# ==========================================

# ------------------------------------------
# 🐳 ORCHESTRATION PROFILES
# ------------------------------------------
# Comma-separated list of services to start.
# Available Profiles: contract, server, market
# Leave empty to start base infrastructure only.
COMPOSE_PROFILES=contract,server,market

# ------------------------------------------
# 🚪 ALTERNATIVE PORTS CONFIGURATION
# ------------------------------------------
# Base Infrastructure Ports
POSTGRES_PORT=5433
REDIS_PORT=6380

# Profile: Contract (Hardhat)
HARDHAT_PORT=8546

# Profile: Server (SmartFox & AP-Login)
SFS_HTTP_PORT=8081
SFS_HTTPS_PORT=8444
SFS_TCP_PORT=9934
SFS_UDP_PORT=9934
SFS_ADMIN_PORT=9899
AP_LOGIN_PORT=8121

# Profile: Market (AP-Market, Market API, Blockchain Center)
AP_MARKET_PORT=9121
MARKET_API_PORT=3001
MARKET_FRONTEND_PORT=5175
BLOCKCHAIN_CENTER_PORT=3004

# Client Frontend Port (Running outside docker)
CLIENT_VITE_PORT=5176

# ------------------------------------------
# 🔐 SHARED SECRETS & ENVIRONMENT VARIABLES
# ------------------------------------------
JWT_LOGIN_SECRET=AVRE_SECRET_123456
JWT_BEARER_SECRET=AVRE_BEARER_123456
AP_LOGIN_TOKEN=AVRE_LOGIN_TOKEN_123456
AES_SECRET=AVRE_AES_SECRET_123456

# Database Connection Info (Internal Docker network)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Blockchain configuration
BLOCKCHAIN_CHAIN_ID=1337
# Network info for clients/backends
VITE_API_HOST=http://localhost:${AP_LOGIN_PORT}/web
VITE_MARKET_API_HOST=http://localhost:${MARKET_API_PORT}
