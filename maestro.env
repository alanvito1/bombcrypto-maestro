# ==============================================================================
# BOMB CRYPTO MAESTRO - CENTRALIZED ENVIRONMENT CONFIGURATION
# ==============================================================================

# GLOBAL INFRASTRUCTURE
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# NETWORK SETTINGS (MODERN RANGE 3005+ / 8005+)
NETWORK=bsc
USE_MOCK_DATA=true
IS_PROD=false

# INTERNAL SERVICE URLS
RPC_API_URL=http://rpc-proxy:8105
BLOCKCHAIN_CENTER_API_URL=http://blockchain-api:3005
MARKET_API_URL=http://market-api:3007
LOGIN_API_URL=http://login-api:8006
PVP_API_URL=http://pvp-api:8007
GAME_SERVER_URL=ws://game-server:9933

# DATABASE CONNECTION STRINGS (INTERNAL)
# Market DB
MARKET_POSTGRES_CONN_STR="postgresql://postgres:postgres@db:5432/market?search_path=bsc&sslmode=disable"
# Game/Server DB
BOMBCRYPTO_POSTGRES_CONN_STR="postgres://postgres:postgres@db:5432/bombcrypto"
# Login DB
LOGIN_POSTGRES_CONN_STR="postgres://postgres:postgres@db:5432/bombcrypto2"

# COMPONENT SPECIFIC
SERVER_ID="maestro-dev-1"
JWT_LOGIN_SECRET="maestro_secret_login_token"
JWT_BEARER_SECRET="maestro_secret_server_token"

# TIMEOUTS & RETRIES
SUBSCRIBER_BLOCK_RETRY_TIMEOUT=10000
REFRESH_INTERVAL=5000
